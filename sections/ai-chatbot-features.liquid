{% schema %}
{
  "name": "AI Chatbot Features",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Powerful Features"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Everything you need to automate support and drive sales on Shopify."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4f7f6"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Feature Title",
          "default": "Instant Responses"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Provide zero wait time for your customers 24/7."
        },
        {
          "type": "html",
          "id": "svg_icon",
          "label": "SVG Icon (Code)",
          "default": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><polyline points=\"12 6 12 12 16 14\"></polyline></svg>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AI Chatbot Features",
      "category": "Chatbot Marketing",
      "blocks": [
        { "type": "feature", "settings": { "title": "Instant Responses", "description": "Reply to visitors without any delays, 24/7." } },
        { "type": "feature", "settings": { "title": "Custom Workflows", "description": "Design flows for sales, support, and leads." } },
        { "type": "feature", "settings": { "title": "API-Ready Integration", "description": "Easily hook up with external LLMs and tools via REST APIs." } },
        { "type": "feature", "settings": { "title": "Easy Customization", "description": "Matches your brand colors, tone, and messaging effortlessly." } }
      ]
    }
  ]
}
{% endschema %}

<style>
  .ai-features-wrapper {
    background-color: {{ section.settings.bg_color }};
    padding: 100px 20px;
    font-family: 'Inter', sans-serif;
  }
  .ai-features-container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .ai-features-header {
    text-align: center;
    margin-bottom: 60px;
  }
  .ai-features-heading {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 16px;
    color: #000;
    letter-spacing: -0.01em;
  }
  .ai-features-subheading {
    font-size: 1.125rem;
    color: #555;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.5;
  }
  
  .ai-features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 40px;
  }
  
  .ai-feature-item {
    background: #fff;
    padding: 40px 30px;
    border-radius: 20px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid #f0f0f0;
  }
  
  .ai-feature-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.08);
  }
  
  .ai-feature-icon {
    width: 48px;
    height: 48px;
    color: #000;
    margin-bottom: 24px;
    background: #f4f7f6;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ai-feature-icon svg {
    width: 24px;
    height: 24px;
  }
  
  .ai-feature-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: #111;
  }
  
  .ai-feature-desc {
    font-size: 1rem;
    color: #666;
    line-height: 1.6;
  }
  
  @media (max-width: 768px) {
    .ai-features-wrapper { padding: 60px 20px; }
    .ai-features-heading { font-size: 2rem; }
  }
</style>

<div class="ai-features-wrapper">
  <div class="ai-features-container">
    <div class="ai-features-header">
      <h2 class="ai-features-heading">{{ section.settings.heading | escape }}</h2>
      <p class="ai-features-subheading">{{ section.settings.subheading | escape }}</p>
    </div>
    
    <div class="ai-features-grid">
      {% for block in section.blocks %}
        <div class="ai-feature-item" {{ block.shopify_attributes }}>
          <div class="ai-feature-icon">
            {{ block.settings.svg_icon }}
          </div>
          <h3 class="ai-feature-title">{{ block.settings.title | escape }}</h3>
          <p class="ai-feature-desc">{{ block.settings.description | escape }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
