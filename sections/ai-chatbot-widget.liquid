{% schema %}
{
  "name": "AI Chatbot Widget",
  "settings": [
    {
      "type": "collection",
      "id": "enquiry_collection",
      "label": "Select Collection for Enquiry"
    }
  ],
  "presets": [
    {
      "name": "AI Chatbot Widget",
      "category": "Chatbot Marketing"
    }
  ]
}
{% endschema %}

{{ 'ai-chatbot-widget.css' | asset_url | stylesheet_tag }}

<script>
  window.chatbotProductsData = [];
  {% if section.settings.enquiry_collection != blank %}
    {% assign selected_col = collections[section.settings.enquiry_collection] %}
    {% for product in selected_col.products limit: 10 %}
      window.chatbotProductsData.push({
        title: {{ product.title | json }},
        handle: {{ product.handle | json }},
        image: {{ product.featured_image | img_url: 'medium' | json }},
        price: {{ product.price | money | json }}
      });
    {% endfor %}
  {% else %}
    console.log("No collection selected for Chatbot AI.");
  {% endif %}
</script>

<div id="ai-chatbot-container" class="ai-chatbot-container" style="display: none;">
  <!-- Loading state handled via JS to prevent CLS, display block after JS parses -->
  
  <!-- Floating Toggle Button -->
  <button id="ai-chatbot-toggle" class="ai-chatbot-toggle" aria-label="Toggle Chatbot">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/>
    </svg>
  </button>

  <!-- Expandable Chat Window -->
  <div class="ai-chatbot-window">
    
    <!-- Header -->
    <div class="ai-chatbot-header">
      <div class="ai-chatbot-header-info">
        <div class="ai-chatbot-avatar">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M21 10.975V8a2 2 0 00-2-2h-3.26a4.5 4.5 0 00-7.48 0H5a2 2 0 00-2 2v2.975A3 3 0 002 14v2a3 3 0 003 3h1v1h2v-1h8v1h2v-1h1a3 3 0 003-3v-2a3 3 0 00-1-3.025zM12 4.5a2.5 2.5 0 012.36 1.5H9.64A2.5 2.5 0 0112 4.5zM20 16a1 1 0 01-1 1h-1.5a.5.5 0 00-.5.5v1h-2v-1.5a.5.5 0 00-.5-.5h-3a.5.5 0 00-.5.5v1.5H9v-1.5a.5.5 0 00-.5-.5H7a1 1 0 01-1-1v-2a1 1 0 011-1h12a1 1 0 011 1v2z"/>
          </svg>
        </div>
        <div>
          <h3 class="ai-chatbot-title">{{ shop.name }} AI</h3>
          <span class="ai-chatbot-status">Online and Ready</span>
        </div>
      </div>
      <button id="ai-chatbot-close" class="ai-chatbot-close" aria-label="Close Chat">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
        </svg>
      </button>
    </div>

    <!-- Message Area (Body) -->
    <div id="ai-chatbot-body" class="ai-chatbot-body">
      <!-- Dynamic Messages injected here via JS -->
    </div>

    <!-- Input Area (Footer) -->
    <div class="ai-chatbot-footer">
      <div class="ai-chatbot-input-wrapper">
        <input 
          type="text" 
          id="ai-chatbot-input" 
          class="ai-chatbot-input" 
          placeholder="Type your message..." 
          autocomplete="off"
        >
        <button id="ai-chatbot-send" class="ai-chatbot-send" aria-label="Send Message">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
          </svg>
        </button>
      </div>
    </div>
    
  </div>
</div>

<script src="{{ 'ai-chatbot-widget.js' | asset_url }}" defer></script>
<script>
  // Ensure the widget displays block immediately once parsed, to prevent CLS
  document.addEventListener("DOMContentLoaded", function() {
    document.getElementById("ai-chatbot-container").style.display = "block";
  });
</script>
