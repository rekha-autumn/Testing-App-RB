{% schema %}
{
  "name": "AI Chatbot CTA",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready to Automate Your Store?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Join thousands of merchants using our AI chatbot to increase conversions and handle customer support."
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Primary Button",
      "default": "Try it Now"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Primary Link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary Button",
      "default": "Contact Sales"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "AI Chatbot CTA",
      "category": "Chatbot Marketing"
    }
  ]
}
{% endschema %}

<style>
  .ai-cta-wrapper {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 100px 20px;
    font-family: 'Inter', sans-serif;
    text-align: center;
  }
  .ai-cta-container {
    max-width: 800px;
    margin: 0 auto;
  }
  .ai-cta-heading {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
    color: inherit;
  }
  .ai-cta-subheading {
    font-size: 1.25rem;
    line-height: 1.6;
    margin-bottom: 40px;
    opacity: 0.9;
    color: inherit;
  }
  
  .ai-cta-buttons {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  
  .ai-cta-btn {
    padding: 16px 32px;
    font-size: 1.125rem;
    font-weight: 600;
    border-radius: 50px;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  
  .ai-cta-btn-primary {
    background: #fff;
    color: #000;
    box-shadow: 0 4px 14px 0 rgba(255, 255, 255, 0.39);
  }
  
  .ai-cta-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255,255,255,0.4);
  }
  
  .ai-cta-btn-secondary {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255,255,255,0.3);
  }
  
  .ai-cta-btn-secondary:hover {
    border-color: #fff;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .ai-cta-wrapper { padding: 60px 20px; }
    .ai-cta-heading { font-size: 2.25rem; }
  }
</style>

<div class="ai-cta-wrapper">
  <div class="ai-cta-container">
    <h2 class="ai-cta-heading">{{ section.settings.heading | escape }}</h2>
    <p class="ai-cta-subheading">{{ section.settings.subheading | escape }}</p>
    
    <div class="ai-cta-buttons">
      <a href="{{ section.settings.button_link_1 | default: '#' }}" class="ai-cta-btn ai-cta-btn-primary" id="ai-cta-trigger">
        {{ section.settings.button_label_1 | escape }}
      </a>
      {% if section.settings.button_label_2 != blank %}
        <a href="{{ section.settings.button_link_2 | default: '/contact' }}" class="ai-cta-btn ai-cta-btn-secondary">
          {{ section.settings.button_label_2 | escape }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

<script>
  // Trigger open chatbot on the CTA button if link is '#'
  document.addEventListener("DOMContentLoaded", () => {
    const triggerCta = document.getElementById("ai-cta-trigger");
    if(triggerCta) {
      triggerCta.addEventListener("click", (e) => {
        if (triggerCta.getAttribute("href") === "#") {
          e.preventDefault();
          const toggleBtn = document.getElementById("ai-chatbot-toggle");
          if (toggleBtn) {
            toggleBtn.click();
          } else {
            alert("Please include the ai-chatbot-widget snippet in your theme!");
          }
        }
      });
    }
  });
</script>
