{% schema %}
{
  "name": "AI Chatbot Flow",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How it works"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our straightforward process for handling customer inquiries seamlessly."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Flow Step",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Customer Asks"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Visitor queries about products, shipping, or returns."
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "default": "💬"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AI Chatbot Flow",
      "category": "Chatbot Marketing",
      "blocks": [
        { "type": "step", "settings": { "title": "Customer Asks", "description": "Visitor queries about products, shipping, or rules.", "icon": "💬" } },
        { "type": "step", "settings": { "title": "AI Analyzes", "description": "The chatbot matches intent instantly.", "icon": "🧠" } },
        { "type": "step", "settings": { "title": "Instant Reply", "description": "Accurate answers sent in real-time.", "icon": "⚡" } },
        { "type": "step", "settings": { "title": "Action Taken", "description": "Sales conversion or support ticket created.", "icon": "✅" } }
      ]
    }
  ]
}
{% endschema %}

<style>
  .ai-flow-wrapper {
    background-color: {{ section.settings.bg_color }};
    padding: 80px 20px;
    font-family: 'Inter', sans-serif;
  }
  .ai-flow-container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }
  .ai-flow-heading {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #111;
  }
  .ai-flow-subheading {
    font-size: 1.125rem;
    color: #666;
    margin-bottom: 60px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .ai-flow-timeline {
    display: flex;
    justify-content: center;
    align-items: stretch;
    gap: 20px;
    flex-wrap: wrap;
    position: relative;
  }
  
  .ai-flow-card {
    flex: 1;
    min-width: 240px;
    background: #fff;
    border: 1px solid #eaeaea;
    border-radius: 16px;
    padding: 32px 24px;
    position: relative;
    box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .ai-flow-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.08);
  }

  .ai-flow-icon {
    width: 60px;
    height: 60px;
    background: #f9fafb;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    margin-bottom: 24px;
    border: 1px solid #eee;
  }
  
  .ai-flow-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 12px;
    color: #000;
  }
  
  .ai-flow-desc {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.5;
  }
  
  .ai-flow-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ddd;
  }

  /* Remove arrow on last child or mobile wrap */
  @media (max-width: 900px) {
    .ai-flow-arrow { display: none; }
    .ai-flow-card { flex: 1 1 45%; }
  }
  @media (max-width: 500px) {
    .ai-flow-card { flex: 1 1 100%; }
  }
</style>

<div class="ai-flow-wrapper">
  <div class="ai-flow-container">
    <h2 class="ai-flow-heading">{{ section.settings.heading | escape }}</h2>
    <p class="ai-flow-subheading">{{ section.settings.subheading | escape }}</p>
    
    <div class="ai-flow-timeline">
      {% for block in section.blocks %}
        <div class="ai-flow-card" {{ block.shopify_attributes }}>
          <div class="ai-flow-icon">{{ block.settings.icon }}</div>
          <h3 class="ai-flow-title">{{ block.settings.title | escape }}</h3>
          <p class="ai-flow-desc">{{ block.settings.description | escape }}</p>
        </div>
        
        {% unless forloop.last %}
          <div class="ai-flow-arrow">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </div>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</div>
